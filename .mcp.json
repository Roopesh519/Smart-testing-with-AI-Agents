{
  "mcpServers": {
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "@playwright/mcp@latest",
        "--browser",
        "chromium",
        "--caps",
        "vision",
        "--viewport-size",
        "1920x1080",
        "--user-data-dir",
        "/home/user/.playwright-zoodpay-profile"
      ],
      "env": {}
    }
  }
}
